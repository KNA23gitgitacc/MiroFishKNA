# ===== LLM Configuration =====
# For local Ollama (default — no API key needed):
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b

# For cloud LLM (e.g., OpenAI):
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# ===== Neo4j Configuration =====
# Local Neo4j (runs via docker-compose, no account needed)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Embedding Configuration =====
# Local Ollama embedding model
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# ===== Ollama Context Window =====
# Increase if prompts get truncated (default Ollama is 2048, we use 8192)
OLLAMA_NUM_CTX=8192

# ===== OASIS Simulation =====
OASIS_DEFAULT_MAX_ROUNDS=10

# ===== Flask =====
FLASK_DEBUG=false
# SECRET_KEY is auto-generated if not set
